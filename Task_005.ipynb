   "source": [
    "from math import gcd\n",
    "\n",
    "def lcm(a, b):\n",
    "    return a * b // gcd(a, b)\n",
    "\n",
    "result = 1\n",
    "for n in range(1, 21):\n",
    "    result = lcm(result, n)\n",
    "\n",
    "print(result)"
   ],
